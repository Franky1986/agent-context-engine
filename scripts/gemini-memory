#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
DEFAULT_ROOT="__AGENT_MEMORY_ROOT__"

if [[ -n "${AGENT_MEMORY_ROOT:-}" ]]; then
  WORKMANAGEMENT_ROOT="$AGENT_MEMORY_ROOT"
elif [[ "$DEFAULT_ROOT" != "__AGENT_MEMORY_ROOT__" ]]; then
  WORKMANAGEMENT_ROOT="$DEFAULT_ROOT"
elif [[ -f "$SCRIPT_DIR/../SKILL.md" && "$(basename "$(dirname "$SCRIPT_DIR")")" = "agent-context-engine" && "$(basename "$(dirname "$(dirname "$SCRIPT_DIR")")")" = "skills" ]]; then
  WORKMANAGEMENT_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
elif [[ -f "$SCRIPT_DIR/../SKILL.md" ]]; then
  WORKMANAGEMENT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
else
  WORKMANAGEMENT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

LAUNCH_CWD="${PWD}"

if [[ ! -d "$WORKMANAGEMENT_ROOT" ]]; then
  echo "gemini-memory: missing Agent Context Engine root: $WORKMANAGEMENT_ROOT" >&2
  exit 1
fi

if [[ ! -f "$WORKMANAGEMENT_ROOT/.gemini/settings.json" ]]; then
  echo "gemini-memory: missing hooks config: $WORKMANAGEMENT_ROOT/.gemini/settings.json" >&2
  exit 1
fi

LAUNCH_CWD="${PWD}"
export AGENT_MEMORY_LAUNCH_CWD="$LAUNCH_CWD"
export AGENT_MEMORY_ROOT="$WORKMANAGEMENT_ROOT"

# Gemini loads hooks from the current working directory. Start from the Agent
# Memory root so the central hooks are loaded, then include the original launch
# directory in the workspace.
cd "$WORKMANAGEMENT_ROOT"
exec gemini --include-directories "$LAUNCH_CWD" "$@"
